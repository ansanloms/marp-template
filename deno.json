{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "fmt": {
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": { "tags": ["recommended"] },
    "plugins": ["jsr:@aireone/deno-lint-curly"]
  },
  "exclude": ["dist/"],
  "imports": {
    "@marp-team/marp-cli": "npm:@marp-team/marp-cli@4.4.0",
    "@marp-team/marp-core": "npm:@marp-team/marp-core@4.3.0",
    "@proofdict/textlint-rule-proofdict": "npm:@proofdict/textlint-rule-proofdict@3.1.2",
    "@shikijs/markdown-it": "npm:@shikijs/markdown-it@4.0.2",
    "@shikijs/transformers": "npm:@shikijs/transformers@4.0.2",
    "@std/encoding": "jsr:@std/encoding@1.0.10",
    "@std/html": "jsr:@std/html@1.0.6",
    "@std/media-types": "jsr:@std/media-types@1.1.0",
    "@std/path": "jsr:@std/path@1.1.4",
    "@textlint-ja/textlint-rule-preset-ai-writing": "npm:@textlint-ja/textlint-rule-preset-ai-writing@1.7.0",
    "mermaid": "npm:mermaid@11.15.0",
    "markdown-it-github-alerts": "npm:markdown-it-github-alerts@1.0.1",
    "textlint": "npm:textlint@15.7.0",
    "textlint-filter-rule-comments": "npm:textlint-filter-rule-comments@1.3.0",
    "textlint-rule-preset-ja-spacing": "npm:textlint-rule-preset-ja-spacing@2.4.3",
    "textlint-rule-preset-ja-technical-writing": "npm:textlint-rule-preset-ja-technical-writing@12.0.2",
    "textlint-rule-preset-jtf-style": "npm:textlint-rule-preset-jtf-style@3.0.3",
    "nord-marp-theme/": "https://cdn.jsdelivr.net/gh/ansanloms/nord-marp-theme@0.3.1/"
  },
  "tasks": {
    "marp": {
      "description": "Run marp command",
      "command": "deno --quiet run --unstable-raw-imports --allow-env --allow-sys --allow-run --allow-read --allow-write --allow-net @marp-team/marp-cli"
    },
    "textlint": {
      "description": "Run textlint command",
      "command": "deno --quiet run --allow-env --allow-read --allow-sys --allow-write --allow-net textlint"
    },
    "lint": "deno task lint:deno && deno task lint:textlint .",
    "lint:deno": "deno lint && deno fmt --check",
    "lint:textlint": "deno task textlint --ignore-path .gitignore",
    "fix": "deno task fix:deno && deno task fix:textlint .; deno task lint",
    "fix:deno": "deno lint --fix && deno fmt",
    "fix:textlint": "deno task textlint --ignore-path .gitignore --fix",
    "clean": "rm -rf ./dist",
    "check": "deno check **/*.ts",
    "build": "deno task clean; deno task build:html; deno task build:pdf; deno task build:pptx; deno task build:image",
    "build:html": "deno task marp slides.md --config-file marp.config.mjs --output ./dist/slides.html",
    "build:pdf": "deno task marp slides.md --config-file marp.config.mjs --allow-local-files --pdf-outlines --output ./dist/slides.pdf",
    "build:pptx": "deno task marp slides.md --config-file marp.config.mjs --allow-local-files --pptx --output ./dist/slides.pptx",
    "build:image": "deno task marp slides.md --config-file marp.config.mjs --allow-local-files --images png --output ./dist/png/slide.png"
  }
}
